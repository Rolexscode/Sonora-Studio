generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  products Product[]
}

model Product {
  id         Int       @id @default(autoincrement())
  name       String
  categoryId Int?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  price     Float
  rating    Float
  inStock   Boolean
  stock     Int     @default(0)
  isNew     Boolean
  desc      String
  specs     String
  image     String
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
  name     String
  role     String @default("CUSTOMER") // ADMIN or CUSTOMER
  purchases Purchase[]
}

model Purchase {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  total     Float
  createdAt DateTime @default(now())
  items     String   // JSON string of {productId, name, price, quantity}
  paymentDetails String? // JSON string of [{method, amount}]
}

model Promotion {
  id         Int      @id @default(autoincrement())
  title      String
  discount   Float    // percentage, e.g., 30 for 30%
  startDate  DateTime
  endDate    DateTime
  isActive   Boolean  @default(true)
  targetType String   // "ALL", "CATEGORY", "PRODUCT"
  targetId   Int?     // Category ID or Product ID
}
